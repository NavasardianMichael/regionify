# Origin of the Regionify web app (links from marketing go here). No trailing slash.
# Required. Match CLIENT_URL used by the server and client in each environment.
CLIENT_URL=

# API origin for Playwright scripts (optional). Defaults to CLIENT_URL in production,
# or http://localhost:9002 when CLIENT_URL is http://localhost:7002.
API_BASE_URL=

# Google Search Console verification (optional)
GOOGLE_SITE_VERIFICATION=

# Credentials for the playwright-asset-generator.ts automation script.
# The account must be on the Chronographer tier (required for animated exports and embed).
REGIONIFY_EMAIL=
REGIONIFY_PASSWORD=
PLAYWRIGHT_WORKERS=