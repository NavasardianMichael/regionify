---
import { MarketingButton } from '@/components/ui/MarketingButton/MarketingButton.tsx';

const CLIENT_URL = import.meta.env.CLIENT_URL;
---

<nav class="sticky top-0 z-50 shrink-0 border-b border-gray-200 bg-white shadow-sm">
  <div
    class="flex items-center justify-between gap-2 px-3 py-3 md:px-6"
  >
    <a
      href={CLIENT_URL}
      class="flex shrink-0 items-center outline-offset-2 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary [&_img]:max-h-10 [&_img]:w-auto [&_img]:max-w-[min(160px,42vw)] [&_img]:object-contain [&_img]:object-left md:[&_img]:max-h-11"
    >
      <img src="/logo.png" alt="Regionify" loading="eager" fetchpriority="high" />
    </a>
    <MarketingButton type="primary" href={`${CLIENT_URL}/projects/new`}>
      Open App
    </MarketingButton>
  </div>
</nav>
