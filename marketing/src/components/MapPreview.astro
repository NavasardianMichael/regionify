---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import { formatNumber } from '@/data/parseCountries';
import type { CountryRow, DivisionRow } from '@/data/parseCountries';

interface Props {
  country: CountryRow;
  divisions: DivisionRow[];
}

const { country, divisions } = Astro.props;

const values = divisions.map((d) => d.value);
const minVal = Math.min(...values);
const maxVal = Math.max(...values);

function interpolateColor(t: number): string {
  // light primary-100 (#dbeafe-ish) → brand primary (#18294D)
  const light = { r: 219, g: 234, b: 254 };
  const dark = { r: 24, g: 41, b: 77 };
  const r = Math.round(light.r + (dark.r - light.r) * t);
  const g = Math.round(light.g + (dark.g - light.g) * t);
  const b = Math.round(light.b + (dark.b - light.b) * t);
  return `rgb(${r},${g},${b})`;
}

const colorMap = new Map<string, { color: string; division: DivisionRow }>();
for (const div of divisions) {
  const t = maxVal === minVal ? 0.5 : (div.value - minVal) / (maxVal - minVal);
  colorMap.set(div.svg_id, { color: interpolateColor(t), division: div });
}

let svgContent = '';
try {
  let raw = readFileSync(join(process.cwd(), 'public/svgs', country.map_file), 'utf-8');
  raw = raw.replace(/\s+width="[^"]*"/, '').replace(/\s+height="[^"]*"/, '');
  // Inject fill color and stroke for each matched path
  raw = raw.replace(/(<path\s[^>]*?)id="([^"]+)"([^>]*?>)/g, (_match, pre, id, post) => {
    const entry = colorMap.get(id);
    if (!entry) return `${pre}id="${id}"${post}`;
    return `${pre}id="${id}" fill="${entry.color}" stroke="white" stroke-width="2"${post}`;
  });
  svgContent = raw;
} catch {
  svgContent = '';
}

const minDivision = divisions.reduce((a, b) => (a.value < b.value ? a : b));
const maxDivision = divisions.reduce((a, b) => (a.value > b.value ? a : b));
---

<section class="bg-gray-50 py-16 md:py-20">
  <div class="mx-auto max-w-6xl px-4 md:px-6">
    <h2 class="text-primary mb-2 text-center text-2xl font-bold md:text-3xl">
      {country.dataset_label}
    </h2>
    <p class="mb-8 text-center text-sm text-gray-500">
      {country.name_en} · {country.dataset_year} · Source:
      <a
        href={country.dataset_source_url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-primary hover:underline"
      >
        {country.dataset_source}
      </a>
    </p>

    <div class="flex flex-col items-center gap-8 md:flex-row md:items-start md:gap-12">
      <div class="w-full max-w-lg flex-1">
        {
          svgContent ? (
            <div
              class="w-full"
              aria-label={`Choropleth map of ${country.name_en} showing ${country.dataset_label}`}
              set:html={svgContent}
            />
          ) : (
            <div class="bg-primary-100 flex aspect-square items-center justify-center rounded-lg text-gray-400">
              Map unavailable
            </div>
          )
        }
      </div>

      <div class="w-full max-w-sm flex-shrink-0 space-y-4">
        <div>
          <div
            class="h-4 w-full rounded"
            style="background: linear-gradient(to right, rgb(219,234,254), rgb(24,41,77))"
          >
          </div>
          <div class="mt-1 flex justify-between text-xs text-gray-500">
            <span
              >{formatNumber(minVal)}
              {country.dataset_unit}</span
            >
            <span
              >{formatNumber(maxVal)}
              {country.dataset_unit}</span
            >
          </div>
        </div>

        <div class="space-y-2">
          <p class="text-xs font-semibold uppercase tracking-wide text-gray-400">Highest</p>
          <div class="flex items-center gap-3">
            <div
              class="h-4 w-4 flex-shrink-0 rounded-sm"
              style={`background-color: ${interpolateColor(1)}`}
            >
            </div>
            <span class="text-sm font-medium text-gray-800">{maxDivision.name_en}</span>
            <span class="ml-auto text-sm text-gray-500"
              >{formatNumber(maxDivision.value)} {country.dataset_unit}</span
            >
          </div>
          <p class="mt-3 text-xs font-semibold uppercase tracking-wide text-gray-400">Lowest</p>
          <div class="flex items-center gap-3">
            <div
              class="h-4 w-4 flex-shrink-0 rounded-sm"
              style={`background-color: ${interpolateColor(0)}`}
            >
            </div>
            <span class="text-sm font-medium text-gray-800">{minDivision.name_en}</span>
            <span class="ml-auto text-sm text-gray-500"
              >{formatNumber(minDivision.value)} {country.dataset_unit}</span
            >
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-4">
          <p class="text-xs font-medium uppercase tracking-wide text-gray-400">About this data</p>
          <p class="mt-2 text-sm leading-relaxed text-gray-600">
            {country.dataset_label} across {country.division_count}
            {country.division_type.toLowerCase()} of {country.name_en} ({country.dataset_year}).
            Data sourced from
            <a
              href={country.dataset_source_url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-primary hover:underline"
            >
              {country.dataset_source}
            </a>.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
