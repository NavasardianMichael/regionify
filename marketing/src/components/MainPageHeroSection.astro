---
import { MarketingButton } from '@/components/ui/MarketingButton/MarketingButton.tsx';
import { MarketingTitle } from '@/components/ui/MarketingTitle.tsx';
---

<section class="bg-primary relative overflow-hidden px-6 py-20 md:py-28 lg:py-32">
  <div class="relative z-10 mx-auto w-full max-w-5xl">
    <div class="flex flex-col gap-8">
      <div class="max-w-2xl text-left">
        <MarketingTitle
          level={1}
          colorScheme="dark"
        >
          Choropleth maps by country
        </MarketingTitle>
        <p class="mb-0 text-white/80 leading-relaxed text-balance">
          Enjoy visualizing administrative divisions based on your regional data, and geographic for
          countries worldwide with Regionify. Create your own maps and export them as PNG, SVG, animated GIF, or an embeddable iframe.
        </p>
      </div>

      <div class="flex flex-wrap justify-start gap-3">
        <MarketingButton type="dashed" colorScheme="dark" target='_blank' href={`${import.meta.env.CLIENT_URL}/projects/new`}>
          Start mapping
        </MarketingButton>
        <MarketingButton type="dashed" colorScheme="dark" target='_blank' href={`${import.meta.env.CLIENT_URL}/billing`}>
          View plans
        </MarketingButton>
      </div>
    </div>
  </div>
</section>
