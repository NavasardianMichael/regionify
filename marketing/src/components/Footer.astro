---
import { MarketingButton } from '@/components/ui/MarketingButton/MarketingButton.tsx';

const CLIENT_URL = import.meta.env.CLIENT_URL;
const year = new Date().getFullYear();
---

<footer class="border-t border-gray-200 bg-white py-8">
  <div class="mx-auto max-w-6xl px-4 md:px-6">
    <div class="flex flex-col items-center gap-3 text-center text-sm text-gray-500 md:flex-row md:justify-between md:text-left">
      <p>
        © {year}
        <MarketingButton type="link" href={CLIENT_URL}>
          Regionify
        </MarketingButton>
        — Create choropleth maps for any country or region.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-6 md:justify-end">
        <MarketingButton type="link" muted href={CLIENT_URL}>
          Home
        </MarketingButton>
        <MarketingButton type="link" muted href={`${CLIENT_URL}/pricing`}>
          Pricing
        </MarketingButton>
        <MarketingButton type="link" muted href={`${CLIENT_URL}/contact`}>
          Contact
        </MarketingButton>
      </div>
    </div>
  </div>
</footer>
