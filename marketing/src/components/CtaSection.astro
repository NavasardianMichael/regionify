---
import { Link } from '@/components/ui/Link.tsx';

interface Props {
  countryName: string;
  divisionType: string;
}

const { countryName, divisionType } = Astro.props;
const CLIENT_URL = import.meta.env.CLIENT_URL;
---

<section class="bg-primary py-16 md:py-24">
  <div class="mx-auto w-full max-w-6xl px-4 text-center md:px-6">
    <h2 class="mx-auto mb-4 w-full max-w-4xl text-3xl font-bold text-white md:text-4xl">
      Create your own {countryName} choropleth map
    </h2>
    <p class="mx-auto mb-8 w-full max-w-[36rem] text-pretty text-lg text-white/80">
      Import your data, color {divisionType.toLowerCase()} by any metric, and export in seconds.
      Free to start — no credit card required.
    </p>
    <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
      <Link appearance="dashed" colorScheme="dark" href={`${CLIENT_URL}/projects/new`}>
        Start for free
      </Link>
      <Link appearance="dashed" colorScheme="dark" href={`${CLIENT_URL}/billing`}>
        View pricing →
      </Link>
    </div>
  </div>
</section>
