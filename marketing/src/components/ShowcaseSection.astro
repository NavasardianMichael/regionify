---
import { existsSync, readFileSync } from 'node:fs';
import { dirname, join } from 'node:path';
import { fileURLToPath } from 'node:url';
import { BASE } from '@/helpers/commons';
import { MarketingButton } from '@/components/ui/MarketingButton/MarketingButton';
import ShowcaseItem from './ShowcaseItem.astro';
import { MarketingTitle } from '@/components/ui/MarketingTitle.tsx';
import type { CountryRow } from '@/data/parseCountries';

interface Props {
  country: CountryRow;
}

const { country } = Astro.props;
const { slug, name_en, division_count, division_type } = country;

type ShowcaseItemDef = {
  title: string;
  description: string;
  badge: string;
  assetPath: string;
  assetType: 'image' | 'video' | 'gif' | 'iframe';
};

const embedUrlFile = join(dirname(fileURLToPath(import.meta.url)), '../../../assets', slug, `${slug}-embed-url.txt`);
const embedUrl = existsSync(embedUrlFile) ? readFileSync(embedUrlFile, 'utf-8').trim() : null;

const allItems: ShowcaseItemDef[] = [
  {
    title: `${name_en} choropleth map`,
    description: `Visualize ${name_en}'s ${division_count} ${division_type.toLowerCase()} as a choropleth map. Color regions by any numeric dataset — population, GDP, unemployment, health outcomes, and more. Export as PNG, JPEG, or PDF.`,
    badge: 'Observer (free)',
    assetPath: `${BASE}/assets/${slug}/${slug}-static.png`,
    assetType: 'image',
  },
  {
    title: 'Vector SVG export',
    description: `Export your ${name_en} map as a scalable vector graphic (SVG). Ideal for print publications, editorial illustrations, and web use — scales to any resolution without quality loss.`,
    badge: 'Explorer',
    assetPath: `${BASE}/assets/${slug}/${slug}.svg`,
    assetType: 'image',
  },
  {
    title: 'Animated GIF',
    description: `Bring your ${name_en} data to life. Import historical time-series data and export a looping animated GIF showing how regional values changed over time.`,
    badge: 'Chronographer',
    assetPath: `${BASE}/assets/${slug}/${slug}-animation.gif`,
    assetType: 'gif',
  },
  {
    title: 'MP4 video export',
    description: `Export your ${name_en} time-series map as an MP4 video. Perfect for presentations, reports, and social media posts where motion communicates change more clearly than static images.`,
    badge: 'Chronographer',
    assetPath: `${BASE}/assets/${slug}/${slug}-video.mp4`,
    assetType: 'video',
  },
  {
    title: 'Public share page',
    description: `Share your ${name_en} choropleth map with a public link. Anyone with the URL can view the full interactive map — no account or login required.`,
    badge: 'Explorer',
    assetPath: `${BASE}/assets/${slug}/${slug}-embed-page.png`,
    assetType: 'image',
  },
  ...(embedUrl
    ? [
        {
          title: 'Embeddable iframe',
          description: `Embed your ${name_en} choropleth map anywhere with a single line of HTML. The iframe stays live — viewers always see the latest version of your map, no re-publishing needed.`,
          badge: 'Explorer',
          assetPath: embedUrl,
          assetType: 'iframe' as const,
        },
      ]
    : []),
];
---

<section class="bg-white py-12">
  <div class="mx-auto max-w-6xl px-4 md:px-6">
    <MarketingTitle level={2} className="mb-2 text-center">
      What you can create for {name_en} with <><MarketingButton type="link" href={import.meta.env.CLIENT_URL} className="">Regionify</MarketingButton></>
    </MarketingTitle>
    <p class="mb-12 text-center text-base text-gray-500">
      From static maps to animated time-series — every format, ready to export.
    </p>

    <div class="flex flex-col gap-12">
      {allItems.map((item, i) => (
        <ShowcaseItem
          title={item.title}
          description={item.description}
          badge={item.badge}
          assetPath={item.assetPath}
          assetType={item.assetType}
          reverse={i % 2 === 1}
          index={i}
        />
      ))}
    </div>
  </div>
</section>
