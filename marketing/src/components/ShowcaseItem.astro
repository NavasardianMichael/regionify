---
interface Props {
  title: string;
  description: string;
  badge: string;
  assetPath: string;
  assetType: 'image' | 'video' | 'gif';
  reverse?: boolean;
  index: number;
}

const { title, description, badge, assetPath, assetType, reverse = false, index } = Astro.props;

const badgeColors: Record<string, string> = {
  'All plans': 'bg-gray-100 text-gray-600',
  'Explorer & above': 'bg-primary-100 text-primary-700',
  'Chronographer only': 'bg-primary text-white',
};
const badgeClass = badgeColors[badge] ?? 'bg-gray-100 text-gray-600';
---

<div
  class:list={[
    'flex flex-col gap-8 border-t border-gray-200 pt-8 md:flex-row md:items-center md:gap-12',
    reverse && 'md:flex-row-reverse',
  ]}
>
  <div class="flex-1">
    <span class:list={['inline-block rounded-full px-3 py-1 text-xs font-medium mb-3', badgeClass]}>
      {badge}
    </span>
    <h3 class="text-primary mb-3 text-xl font-semibold">{title}</h3>
    <p class="text-base leading-relaxed text-gray-500">{description}</p>
    <a
      href="https://regionify.com/projects/new"
      class="text-primary mt-4 inline-block text-sm font-medium hover:underline"
    >
      Try it free →
    </a>
  </div>

  <div class="flex-1">
    <div class="aspect-video w-full overflow-hidden rounded-lg border border-dashed border-gray-300 bg-gray-50">
      {
        assetType === 'video' ? (
          <video
            src={assetPath}
            autoplay
            loop
            muted
            playsinline
            class="h-full w-full object-contain"
          />
        ) : (
          <img
            src={assetPath}
            alt={title}
            loading={index === 0 ? 'eager' : 'lazy'}
            class="h-full w-full object-contain"
          />
        )
      }
    </div>
  </div>
</div>
