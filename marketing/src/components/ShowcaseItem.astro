---
import { MarketingButton } from '@/components/ui/MarketingButton/MarketingButton.tsx';
import { MarketingTitle } from '@/components/ui/MarketingTitle.tsx';

interface Props {
  title: string;
  description: string;
  badge: string;
  assetPath: string;
  assetType: 'image' | 'video' | 'gif' | 'iframe';
  reverse?: boolean;
  index: number;
}

const { title, description, badge, assetPath, assetType, reverse = false, index } = Astro.props;

const badgeColors: Record<string, string> = {
  'Observer (free)': 'bg-primary text-white',
  'Explorer': 'bg-cyan-500 text-white',
  'Chronographer': 'bg-amber-500 text-white',
};
const badgeClass = badgeColors[badge] ?? 'bg-primary text-white';
---

<div
  class:list={[
    'flex flex-col gap-8 border-t border-gray-200 pt-8 md:flex-row md:items-center md:gap-12',
    reverse && 'md:flex-row-reverse',
  ]}
>
  <div class="min-w-0 flex-1">
    <span class:list={['inline-block rounded-full px-3 py-1 text-xs font-medium mb-3', badgeClass]}>
      {badge}
    </span>
    <MarketingTitle level={3} className="mb-3">{title}</MarketingTitle>
    <p class="text-base leading-relaxed text-balance text-gray-500" set:html={description} />
    <p class="mt-4">
      <MarketingButton type="link" href={`${import.meta.env.CLIENT_URL}/projects/new`}>
        {badge === 'Observer (free)' ? 'Try it free →' : `Try it with the "${badge}" badge →`}
      </MarketingButton>
    </p>
  </div>

  <div class="min-w-0 flex-1">
    <div class="aspect-video w-full overflow-hidden rounded-lg border border-dashed border-gray-300">
      {
        assetType === 'video' ? (
          <video
            src={assetPath}
            loop
            muted
            playsinline
            controls
            class="h-full w-full object-contain"
          />
        ) : assetType === 'iframe' ? (
          <iframe
            src={assetPath}
            class="h-full w-full border-none"
            allowfullscreen
            loading="lazy"
          />
        ) : (
          <img
            src={assetPath}
            alt={title}
            loading={index === 0 ? 'eager' : 'lazy'}
            class="h-full w-full object-contain"
          />
        )
      }
    </div>
  </div>
</div>
