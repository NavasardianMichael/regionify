---
import Nav from '@/components/Nav.astro';
import { BASE } from '@/helpers/commons';
import Footer from '@/components/Footer.astro';
import { MarketingButton } from '@/components/ui/MarketingButton/MarketingButton.tsx';
import { MarketingTitle } from '@/components/ui/MarketingTitle.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page Not Found | Regionify</title>
    <meta name="description" content="The page you're looking for doesn't exist." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href={`${BASE}/favicon.ico`} />
    <style>
      @import '../styles/global.css';
    </style>
  </head>
  <body class="text-gray-900">
    <div class="flex h-svh min-h-svh flex-col overflow-hidden">
      <Nav />
      <main class="flex flex-col grow overflow-y-auto">
        <div class="flex flex-col grow justify-center mx-auto w-full max-w-6xl px-4 py-16 text-center md:px-6 md:py-24">
          <p class="mb-2 text-6xl font-bold text-gray-200">404</p>
          <MarketingTitle level={1} className="mb-3">Page not found</MarketingTitle>
          <p class="mx-auto mb-8 max-w-96 text-base text-gray-500 text-balance">
            The page you're looking for doesn't exist or has been moved.
          </p>
          <div class="flex justify-center">
            <MarketingButton type="primary" href={`${BASE}/`}>Browse countries</MarketingButton>
          </div>
        </div>
        <Footer />
      </main>
    </div>
  </body>
</html>
