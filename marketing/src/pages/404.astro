---
import Nav from '@/components/Nav.astro';
import { BASE } from '@/helpers/commons';
import Footer from '@/components/Footer.astro';
import { MarketingButton } from '@/components/ui/MarketingButton/MarketingButton.tsx';
import { MarketingTitle } from '@/components/ui/MarketingTitle.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page Not Found | Regionify</title>
    <meta name="description" content="The page you're looking for doesn't exist." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href={`${BASE}/favicon.ico`} />
    <style>
      @import '../styles/global.css';
    </style>
  </head>
  <body class="bg-white text-gray-900">
    <div class="flex h-svh min-h-svh flex-col overflow-hidden">
      <Nav />
      <main class="flex min-h-0 flex-1 items-center justify-center overflow-y-auto">
        <div class="mx-auto flex w-full max-w-6xl flex-col items-center px-4 py-16 text-center md:px-6 md:py-24">
          <p class="mb-2 text-6xl font-bold text-gray-200">404</p>
          <MarketingTitle level={2} className="mb-3">Page not found</MarketingTitle>
          <p class="mb-8 max-w-sm text-base text-gray-500">
            The page you're looking for doesn't exist or has been moved.
          </p>
          <MarketingButton type="primary" href={`${BASE}/`}>Browse countries</MarketingButton>
        </div>
      </main>
      <Footer />
    </div>
  </body>
</html>
