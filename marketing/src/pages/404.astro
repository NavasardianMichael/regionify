---
import Nav from '@/components/Nav.astro';
import { BASE } from '@/helpers/commons';
import { MarketingButton } from '@/components/ui/MarketingButton/MarketingButton.tsx';
import { MarketingTitle } from '@/components/ui/MarketingTitle.tsx';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page Not Found | Regionify</title>
    <meta name="description" content="The page you're looking for doesn't exist." />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href={`${BASE}/favicon.ico`} />
    <style>
      @import '../styles/global.css';
    </style>
  </head>
  <body class="bg-white">
    <Nav />

    <main class="mx-auto flex max-w-6xl flex-col items-center px-4 py-24 text-center md:px-6">
      <p class="mb-2 text-6xl font-bold text-gray-200">404</p>
      <MarketingTitle level={2} className="mb-3">Page not found</MarketingTitle>
      <p class="mb-8 max-w-sm text-base text-gray-500">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <MarketingButton type="primary" href={`${BASE}/`}>Browse countries</MarketingButton>
    </main>

    <footer class="border-t border-gray-200 py-8 text-center text-sm text-gray-500">
      <MarketingButton type="link" muted href={import.meta.env.CLIENT_URL}>
        Regionify
      </MarketingButton>
      — Create choropleth maps for any country or region.
    </footer>
  </body>
</html>
