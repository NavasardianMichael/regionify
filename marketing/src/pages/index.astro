---
import Nav from '@/components/Nav.astro';
import { Link } from '@/components/ui/Link.tsx';
import { getCountries } from '@/data/parseCountries';

const countries = getCountries();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Choropleth Maps by Country | Regionify</title>
    <meta
      name="description"
      content="Browse choropleth maps for countries worldwide. Explore administrative divisions, regional data, and geographic visualizations — all created with Regionify."
    />
    <link rel="canonical" href={`${import.meta.env.CLIENT_URL}/`} />
    <link rel="icon" href="/favicon.ico" />
    <style>
      @import '../styles/global.css';
    </style>
  </head>
  <body class="bg-white">
    <Nav />

    <main class="mx-auto max-w-6xl px-4 py-16 md:px-6">
      <h1 class="text-primary mb-4 text-3xl font-bold md:text-4xl">
        Choropleth maps by country
      </h1>
      <p class="mb-10 text-lg text-gray-500">
        Explore administrative divisions, regional data, and geographic visualizations for countries
        worldwide.
      </p>

      <ul class="grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-4">
        {
          countries.map((c) => (
            <li>
              <Link appearance="card" href={`/${c.slug}/`}>
                <span class="flex w-full items-center gap-3 text-left">
                  <span class="text-2xl">{c.flag_emoji}</span>
                  <span class="min-w-0">
                    <span class="block text-sm font-semibold text-gray-800">{c.name_en}</span>
                    <span class="block text-xs text-gray-400">
                      {c.division_count} {c.division_type.toLowerCase()}
                    </span>
                  </span>
                </span>
              </Link>
            </li>
          ))
        }
      </ul>
    </main>

    <footer class="border-t border-gray-200 py-8 text-center text-sm text-gray-500">
      <Link href={import.meta.env.CLIENT_URL} variant="muted">
        Regionify
      </Link>
      — Create choropleth maps for any country or region.
    </footer>
  </body>
</html>
