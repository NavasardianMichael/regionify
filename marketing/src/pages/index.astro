---
import { MarketingButton } from '@/components/ui/MarketingButton/MarketingButton.tsx';
import { MarketingTitle } from '@/components/ui/MarketingTitle.tsx';
import { getCountries } from '@/data/parseCountries';
import MainPageHeroSection from '@/components/MainPageHeroSection.astro';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import MarketingPage from '@/layouts/MarketingPage.astro';
import { BASE } from '@/helpers/commons';

const countries = getCountries();

const seoTitle = 'Choropleth Maps by Country | Regionify';
const seoDescription =
  'Browse interactive choropleth maps for countries worldwide. Explore administrative divisions, regional data, and geographic visualizations — all created with Regionify.';
const seoKeywords =
  'choropleth maps by country, regional data visualization, interactive country maps, geographic heatmap, Regionify';
---

<MarketingLayout
  seoTitle={seoTitle}
  seoDescription={seoDescription}
  seoKeywords={seoKeywords}
>
  <MarketingPage>
    <MainPageHeroSection />
    <div class="mx-auto max-w-6xl px-4 py-12 md:px-6">
      <MarketingTitle level={2} className="mb-2">
        Browse countries
      </MarketingTitle>
      <p class="mb-10 text-base text-gray-500">
        Open any country page to see map formats, exports, and examples.
      </p>

      <ul class="grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-4">
        {
          countries.map((c) => (
            <li>
              <MarketingButton type="card" href={`${BASE}/${c.slug}/`}>
                <span class="flex w-full items-center gap-3 text-left">
                  <span class="min-w-0">
                    <span class="block text-sm font-semibold text-gray-800">{c.name_en}</span>
                    <span class="block text-xs text-gray-400">
                      {c.division_count} {c.division_type.toLowerCase()}
                    </span>
                  </span>
                </span>
              </MarketingButton>
            </li>
          ))
        }
      </ul>
    </div>
  </MarketingPage>
</MarketingLayout>
