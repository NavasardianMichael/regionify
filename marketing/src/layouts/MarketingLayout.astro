---
import '../styles/global.css';

interface Props {
  seoTitle: string;
  seoDescription: string;
  seoKeywords: string;
  slug: string;
  nameEn?: string;
  nameLocal?: string;
  divisionNames?: string[];
  /** Path beginning with `/` (e.g. `/assets/...`). */
  ogImagePublicPath?: string;
}

const {
  seoTitle,
  seoDescription,
  seoKeywords,
  slug,
  nameEn,
  nameLocal,
  divisionNames,
  ogImagePublicPath,
} = Astro.props;

const CLIENT_URL = import.meta.env.CLIENT_URL;
const canonicalUrl = `${CLIENT_URL}${import.meta.env.BASE_URL}${slug}/`;
const ogImageUrl = ogImagePublicPath
  ? `${CLIENT_URL}${ogImagePublicPath}`
  : `${CLIENT_URL}/og-image.jpg`;

const softwareAppJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Regionify',
  description:
    'Create choropleth maps for any country or region. Import from CSV, Excel, JSON, Google Sheets (including live sync), pasted tabular data, or AI-assisted parsing of unstructured text; customize styling and legends; export as PNG, SVG, GIF, MP4, or PDF.',
  url: CLIENT_URL,
  applicationCategory: 'DataVisualization',
  offers: [
    { '@type': 'Offer', name: 'Observer', price: '0', priceCurrency: 'USD' },
    { '@type': 'Offer', name: 'Explorer', price: '49', priceCurrency: 'USD' },
    { '@type': 'Offer', name: 'Chronographer', price: '149', priceCurrency: 'USD' },
  ],
};

const spatialCoverageJsonLd =
  divisionNames && divisionNames.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'Place',
        name: nameEn,
        ...(nameLocal ? { alternateName: nameLocal } : {}),
        containsPlace: divisionNames.map((name) => ({ '@type': 'Place', name })),
      }
    : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seoTitle}</title>
    <meta name="description" content={seoDescription} />
    <meta name="keywords" content={seoKeywords} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />

    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Regionify" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={seoDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />

    {
      spatialCoverageJsonLd && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(spatialCoverageJsonLd)}
        />
      )
    }
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(softwareAppJsonLd)}
    />
  </head>
  <body class="bg-white text-gray-900">
    <slot />
  </body>
</html>
