---
import '../styles/global.css';
import { BADGE_DETAILS, BADGES } from '@regionify/shared';
import { BASE } from '@/helpers/commons';

interface Props {
  seoTitle: string;
  seoDescription: string;
  seoKeywords: string;
  /** Country slug — omit for the hub index page, which uses `${BASE}/` as its canonical. */
  slug?: string;
  nameEn?: string;
  nameLocal?: string;
  divisionNames?: string[];
  /** Approximate population (head count). */
  populationApprox?: number;
  /** Land area in km². */
  areaKm2?: number;
  /** Path beginning with `/` (e.g. `/assets/...`). */
  ogImagePublicPath?: string;
}

const {
  seoTitle,
  seoDescription,
  seoKeywords,
  slug,
  nameEn,
  nameLocal,
  divisionNames,
  populationApprox,
  areaKm2,
  ogImagePublicPath,
} = Astro.props;

const CLIENT_URL = import.meta.env.CLIENT_URL;
const canonicalUrl = slug ? `${CLIENT_URL}${BASE}/${slug}/` : `${CLIENT_URL}${BASE}/`;
const ogImageUrl = ogImagePublicPath
  ? `${CLIENT_URL}${ogImagePublicPath}`
  : `${CLIENT_URL}/og-image.jpg`;

const softwareAppJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Regionify',
  description:
    'Create choropleth maps for any country or region. Import from CSV, Excel, JSON, Google Sheets (including live sync), pasted tabular data, or AI-assisted parsing of unstructured text; customize styling and legends; export as PNG, SVG, GIF, MP4, or PDF.',
  url: CLIENT_URL,
  applicationCategory: 'DataVisualization',
  offers: [BADGES.observer, BADGES.explorer, BADGES.chronographer].map((badge) => ({
    '@type': 'Offer',
    name: badge.charAt(0).toUpperCase() + badge.slice(1),
    price: String(BADGE_DETAILS[badge].price),
    priceCurrency: 'USD',
  })),
};

const countryJsonLd =
  nameEn
    ? {
        '@context': 'https://schema.org',
        '@type': 'Country',
        name: nameEn,
        ...(nameLocal ? { alternateName: nameLocal } : {}),
        ...(populationApprox != null ? { numberOfPeople: populationApprox } : {}),
        ...(areaKm2 != null
          ? { area: { '@type': 'QuantitativeValue', value: areaKm2, unitCode: 'KMQ' } }
          : {}),
        ...(divisionNames && divisionNames.length > 0
          ? { containsPlace: divisionNames.map((name) => ({ '@type': 'Place', name })) }
          : {}),
      }
    : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{seoTitle}</title>
    <meta name="description" content={seoDescription} />
    <meta name="keywords" content={seoKeywords} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content="index, follow" />
    {import.meta.env.GOOGLE_SITE_VERIFICATION && (
      <meta name="google-site-verification" content={import.meta.env.GOOGLE_SITE_VERIFICATION} />
    )}

    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Regionify" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={seoDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" href={`${BASE}/favicon.ico`} />

    {
      countryJsonLd && (
        <script
          is:inline
          type="application/ld+json"
          set:html={JSON.stringify(countryJsonLd)}
        />
      )
    }
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(softwareAppJsonLd)}
    />
  </head>
  <body class="bg-white text-gray-900">
    <slot />
  </body>
</html>
