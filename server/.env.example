NODE_ENV=development
PORT=9002
LOG_LEVEL=debug

# PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/regionify
POSTGRES_USER=regionify
POSTGRES_PASSWORD=
POSTGRES_DB=regionify
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Sessions
SESSION_SECRET=
SESSION_MAX_AGE=604800000

# CORS / URLs
CORS_ORIGINS=http://localhost:7002
CLIENT_URL=http://localhost:7002

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=10

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:9002/auth/google/callback

# Mail service
MAIL_API_URL=
MAIL_API_KEY=

# Google Gemini (AI parser)
GEMINI_API_KEY=

# Paddle (payments) — omit or leave empty to disable; set PADDLE_SANDBOX=true for sandbox
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_ID_EXPLORER=
PADDLE_PRICE_ID_CHRONOGRAPHER=
PADDLE_SANDBOX=true
